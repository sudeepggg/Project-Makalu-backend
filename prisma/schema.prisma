// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 1. USER & AUTHENTICATION
// ============================================================

model User {
  id                    String   @id @default(uuid())
  username              String   @unique @db.VarChar(50)
  email                 String   @unique @db.VarChar(100)
  passwordHash          String   @db.VarChar(255)
  firstName             String?  @db.VarChar(50)
  lastName              String?  @db.VarChar(50)
  isActive              Boolean  @default(true)
  lastLogin             DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  roles                 UserRole[]
  orders                Order[]
  auditLogs             AuditLog[]
  pricingOverrides      PricingOverride[]

  @@index([email])
  @@index([isActive])
}

model Role {
  id                    String   @id @default(uuid())
  name                  String   @unique @db.VarChar(50)
  description           String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  users                 UserRole[]

  @@index([name])
}

model UserRole {
  id                    String   @id @default(uuid())
  userId                String
  roleId                String
  assignedAt            DateTime @default(now())
  
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                  Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// ============================================================
// 2. CUSTOMER MANAGEMENT
// ============================================================

model CustomerType {
  id                    String   @id @default(uuid())
  name                  String   @unique @db.VarChar(50)
  description           String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  customers             Customer[]

  @@index([name])
}

model Customer {
  id                    String   @id @default(uuid())
  name                  String   @db.VarChar(100)
  customerTypeId        String
  registrationNumber    String?  @unique @db.VarChar(50)
  contactPerson         String?  @db.VarChar(100)
  email                 String?  @unique @db.VarChar(100)
  phone                 String?  @db.VarChar(20)
  website               String?  @db.VarChar(255)
  
  street                String?  @db.VarChar(255)
  city                  String?  @db.VarChar(50)
  state                 String?  @db.VarChar(50)
  zipCode               String?  @db.VarChar(10)
  country               String?  @db.VarChar(50)
  
  creditLimit           Float    @default(0)
  creditUsed            Float    @default(0)
  taxId                 String?  @db.VarChar(50)
  paymentTerms          String?  @db.VarChar(50)
  
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  customerType          CustomerType @relation(fields: [customerTypeId], references: [id])
  orders                Order[]
  payments              Payment[]
  customerPricings      CustomerProductPricing[]
  priceListMappings     PriceListCustomer[]

  @@index([customerTypeId])
  @@index([email])
  @@index([isActive])
  @@index([name])
}

// ============================================================
// 3. PRODUCT & INVENTORY
// ============================================================

model Category {
  id                    String   @id @default(uuid())
  name                  String   @unique @db.VarChar(100)
  description           String?  @db.Text
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  products              Product[]

  @@index([isActive])
}

model UnitOfMeasure {
  id                    String   @id @default(uuid())
  name                  String   @unique @db.VarChar(50)
  abbreviation          String   @unique @db.VarChar(10)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  products              Product[]
}

model Supplier {
  id                    String   @id @default(uuid())
  name                  String   @db.VarChar(100)
  registrationNumber    String?  @unique @db.VarChar(50)
  contactPerson         String?  @db.VarChar(100)
  email                 String?  @db.VarChar(100)
  phone                 String?  @db.VarChar(20)
  
  street                String?  @db.VarChar(255)
  city                  String?  @db.VarChar(50)
  state                 String?  @db.VarChar(50)
  zipCode               String?  @db.VarChar(10)
  country               String?  @db.VarChar(50)
  
  paymentTerms          String?  @db.VarChar(50)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  products              Product[]

  @@index([isActive])
}

model Product {
  id                    String   @id @default(uuid())
  sku                   String   @unique @db.VarChar(50)
  name                  String   @db.VarChar(100)
  description           String?  @db.Text
  categoryId            String
  unitOfMeasureId       String
  supplierId            String?
  
  basePrice             Float    @default(0)
  costPrice             Float?   @default(0)
  reorderLevel          Int      @default(10)
  reorderQuantity       Int      @default(50)
  
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  category              Category @relation(fields: [categoryId], references: [id])
  unitOfMeasure         UnitOfMeasure @relation(fields: [unitOfMeasureId], references: [id])
  supplier              Supplier? @relation(fields: [supplierId], references: [id])
  inventories           Inventory[]
  orderItems            OrderItem[]
  customerPricings      CustomerProductPricing[]
  priceListItems        PriceListItem[]
  stockMovements        StockMovement[]

  @@index([categoryId])
  @@index([supplierId])
  @@index([isActive])
}

model Warehouse {
  id                    String   @id @default(uuid())
  name                  String   @unique @db.VarChar(100)
  location              String?  @db.VarChar(255)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  inventories           Inventory[]
  stockMovements        StockMovement[]

  @@index([isActive])
}

model Inventory {
  id                    String   @id @default(uuid())
  productId             String
  warehouseId           String
  quantityOnHand        Int      @default(0)
  quantityReserved      Int      @default(0)
  quantityAvailable     Int      @default(0)
  lastStockCheckDate    DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  product               Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse             Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
}

model StockMovement {
  id                    String   @id @default(uuid())
  productId             String
  warehouseId           String
  movementType          String   @db.VarChar(50)
  quantity              Int
  referenceType         String?  @db.VarChar(50)
  referenceId           String?
  notes                 String?  @db.Text
  createdAt             DateTime @default(now())
  
  product               Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse             Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([warehouseId])
  @@index([createdAt])
  @@index([movementType])
}

// ============================================================
// 4. PRICING ENGINE
// ============================================================

model PriceList {
  id                    String   @id @default(uuid())
  name                  String   @unique @db.VarChar(100)
  description           String?  @db.Text
  isActive              Boolean  @default(true)
  effectiveDate         DateTime
  expiryDate            DateTime?
  priority              Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  items                 PriceListItem[]
  customerMappings      PriceListCustomer[]

  @@index([isActive])
  @@index([effectiveDate])
}

model PriceListItem {
  id                    String   @id @default(uuid())
  priceListId           String
  productId             String
  price                 Float    @default(0)
  discountPercentage    Float?   @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  priceList             PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product               Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId])
  @@index([priceListId])
  @@index([productId])
}

model PriceListCustomer {
  id                    String   @id @default(uuid())
  priceListId           String
  customerId            String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  priceList             PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  customer              Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([priceListId, customerId])
  @@index([priceListId])
  @@index([customerId])
}

model CustomerProductPricing {
  id                    String   @id @default(uuid())
  customerId            String
  productId             String
  price                 Float    @default(0)
  discountPercentage    Float?   @default(0)
  effectiveDate         DateTime @default(now())
  expiryDate            DateTime?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  customer              Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product               Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  overrides             PricingOverride[]

  @@unique([customerId, productId])
  @@index([customerId])
  @@index([productId])
  @@index([isActive])
}

model PricingOverride {
  id                    String   @id @default(uuid())
  customerProductPricingId String
  userId                String
  oldPrice              Float
  newPrice              Float
  reason                String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  customerProductPricing CustomerProductPricing @relation(fields: [customerProductPricingId], references: [id], onDelete: Cascade)
  user                  User @relation(fields: [userId], references: [id])

  @@index([customerProductPricingId])
  @@index([userId])
}

model PricingHistory {
  id                    String   @id @default(uuid())
  customerId            String
  productId             String
  price                 Float
  discountPercentage    Float?
  pricingRuleType       String   @db.VarChar(50)
  pricingRuleId         String?
  appliedDate           DateTime @default(now())

  @@index([customerId])
  @@index([productId])
  @@index([appliedDate])
}

// ============================================================
// 5. ORDER MANAGEMENT
// ============================================================

model Order {
  id                    String   @id @default(uuid())
  orderNumber           String   @unique @db.VarChar(50)
  customerId            String
  userId                String
  
  status                String   @default("DRAFT")
  subtotal              Float    @default(0)
  discountAmount        Float?   @default(0)
  taxAmount             Float    @default(0)
  total                 Float    @default(0)
  currency              String   @default("NPR")
  
  orderDate             DateTime @default(now())
  confirmedDate         DateTime?
  dispatchedDate        DateTime?
  deliveredDate         DateTime?
  expectedDeliveryDate  DateTime?
  
  notes                 String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  customer              Customer @relation(fields: [customerId], references: [id])
  user                  User @relation(fields: [userId], references: [id])
  items                 OrderItem[]
  payments              Payment[]

  @@index([customerId])
  @@index([userId])
  @@index([status])
  @@index([orderDate])
}

model OrderItem {
  id                    String   @id @default(uuid())
  orderId               String
  productId             String
  quantity              Int
  unitPrice             Float
  discountPercentage    Float?   @default(0)
  lineTotal             Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  order                 Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product               Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// ============================================================
// 6. PAYMENT TRACKING
// ============================================================

model Payment {
  id                    String   @id @default(uuid())
  orderId               String
  customerId            String
  amount                Float    @default(0)
  paymentMethod         String   @db.VarChar(50)
  transactionId         String?  @db.VarChar(100)
  
  status                String   @default("PENDING")
  notes                 String?  @db.Text
  
  paymentDate           DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  order                 Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer              Customer @relation(fields: [customerId], references: [id])

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([paymentDate])
}

// ============================================================
// 7. AUDIT & LOGGING
// ============================================================

model AuditLog {
  id                    String   @id @default(uuid())
  userId                String
  action                String   @db.VarChar(100)
  entityType            String   @db.VarChar(50)
  entityId              String   @db.VarChar(50)
  changes               Json?
  ipAddress             String?  @db.VarChar(50)
  userAgent             String?  @db.Text
  createdAt             DateTime @default(now())
  
  user                  User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}